{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "auth",
	"main": "src/index.ts",
	"compatibility_date": "2025-11-20",
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "auth.call.collectif-pixel.fr",
			"custom_domain": true
		}
	],
	"kv_namespaces": [
		{
			"binding": "FOUNDER_MEMBERS",
			"id": "6b5817196e9e4168ac7119edb0a239d7"
		}
	],
	"vars": {
		"CORS_ORIGIN": "*"
	}
}
